{
  "version": 2,
  "buildCommand": "npx turbo run build --filter=web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api-url.railway.app/api/:path*"
    }
  ]
}
