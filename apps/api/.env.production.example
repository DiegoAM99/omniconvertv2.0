# Production Environment Variables Template
# Copy this to Railway dashboard environment variables

# ============================================
# REQUIRED - Core Configuration
# ============================================
PORT=4000
NODE_ENV=production

# Frontend URL (your Vercel deployment)
FRONTEND_URL=https://omniconvertv2-0.vercel.app

# ============================================
# REQUIRED - Database (Auto-configured by Railway PostgreSQL)
# ============================================
# DATABASE_URL=postgresql://... (automatically added by Railway)

# ============================================
# REQUIRED - Redis Queue (from Upstash)
# ============================================
# Get from: https://console.upstash.com
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_REGION.upstash.io:6379

# ============================================
# REQUIRED - Storage (Cloudflare R2)
# ============================================
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
AWS_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_UPLOADS_BUCKET=omniconvert-uploads
S3_OUTPUTS_BUCKET=omniconvert-outputs

# ============================================
# REQUIRED - Security
# ============================================
# Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING_GENERATE_WITH_OPENSSL

# ============================================
# OPTIONAL - OAuth (if using Google login)
# ============================================
GOOGLE_CLIENT_ID=optional
GOOGLE_CLIENT_SECRET=optional

# ============================================
# OPTIONAL - Monitoring
# ============================================
LOG_LEVEL=info
