# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omniconvert?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Redis (for caching and job queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# CloudConvert API (for audio/video conversions)
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key_here

# Temporary file directory
TEMP_DIR=/tmp

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
S3_UPLOADS_BUCKET="omniconvert-uploads"
S3_OUTPUTS_BUCKET="omniconvert-outputs"

# CloudConvert API
CLOUDCONVERT_API_KEY="your-cloudconvert-api-key"

# Paddle
PADDLE_VENDOR_ID="your-paddle-vendor-id"
PADDLE_API_KEY="your-paddle-api-key"
PADDLE_WEBHOOK_SECRET="your-paddle-webhook-secret"
PADDLE_SANDBOX="true"

# Email (Resend or SendGrid)
EMAIL_API_KEY="your-email-api-key"
EMAIL_FROM="noreply@omniconvert.com"

# App
NODE_ENV="development"
PORT="4000"
FRONTEND_URL="http://localhost:3000"

# File retention (hours)
FILE_RETENTION_HOURS="24"
