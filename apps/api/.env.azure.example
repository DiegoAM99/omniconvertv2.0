# Azure Student Deployment - Environment Variables
# Use these in Azure App Service → Configuration → Application Settings

# ============================================
# Database (Azure Database for PostgreSQL)
# ============================================
# Format: postgresql://USER@SERVER:PASSWORD@SERVER.postgres.database.azure.com:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://omniconvert_admin@omniconvert-db:YOUR_PASSWORD@omniconvert-db.postgres.database.azure.com:5432/postgres?sslmode=require

# ============================================
# Redis (Azure Cache for Redis)
# ============================================
# Format: HOSTNAME:6380,password=KEY,ssl=True,abortConnect=False
REDIS_URL=omniconvert-redis.redis.cache.windows.net:6380,password=YOUR_REDIS_KEY,ssl=True,abortConnect=False

# ============================================
# Blob Storage (Azure Storage Account)
# ============================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=omniconvertstorage;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=omniconvertstorage
AZURE_STORAGE_UPLOADS_CONTAINER=uploads
AZURE_STORAGE_OUTPUTS_CONTAINER=outputs

# ============================================
# App Configuration
# ============================================
NODE_ENV=production
PORT=8080
WEBSITES_PORT=8080

# Frontend URL (your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# ============================================
# Security
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_random_64_character_secret_here

# ============================================
# Optional - OAuth
# ============================================
GOOGLE_CLIENT_ID=optional
GOOGLE_CLIENT_SECRET=optional

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
